# ==========================================
# 智驭能效 (SmartEnergyMaster) 综合忽略清单
# ==========================================

# 1. 操作系统自动生成的文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 2. IDE 配置文件
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 3. 后端：Spring Boot / Java (针对 backend/ 目录)
backend/target/
backend/out/
*.class
*.log
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
# 允许保留 Maven 包装器
!backend/.mvn/wrapper/maven-wrapper.jar

# 4. 前端：Vue / Node.js (针对 frontend/ 目录)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# 5. 算法与数据泵：Python (针对 ai_models/ 目录)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
ai_models/env/
ai_models/venv/
ai_models/.venv/
data/.venv/
.venv/
Pipfile.lock

# 6. 🚨 核心防御：数据与大模型权重 (针对 data/ 和 ai_models/ 目录)
# 绝对不要把庞大的数据集和训练好的模型传到 Git 上！
data/*.csv
data/*.json
data/*.xlsx
# 允许提交一个非常小的示例文件供大家测试联调
!data/sample_data.csv 

ai_models/**/*.h5
ai_models/**/*.pkl
ai_models/**/*.pt
ai_models/**/*.pth
ai_models/**/*.onnx

# 7. 敏感配置 (如数据库密码、云服务器秘钥)
.env
.env.local
.env.*.local
application-prod.yml

# 8. 文档与媒体文件（如果不需要版本控制）
.md
.doc
.docx
.excel
.pdf
.mp4