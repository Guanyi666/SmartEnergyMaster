.claude/settings.local.json
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/.vite/                  # 🆕 合并 workorder: Vite 缓存目录

# 5. 算法与数据泵：Python (针对 ai_models/ 目录)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
ai_models/env/
ai_models/venv/
ai_models/.venv/
data/.venv/
.venv/
Pipfile.lock

# 6. 🚨 核心防御：数据与大模型权重 (针对 data/ 和 ai_models/ 目录)
# 绝对不要把庞大的数据集和训练好的模型传到 Git 上！
data/*.csv
data/*.json
data/*.xlsx
# 允许提交一个非常小的示例文件供大家测试联调
!data/sample_data.csv

ai_models/**/*.h5
ai_models/**/*.pkl
ai_models/**/*.pt
ai_models/**/*.pth
ai_models/**/*.onnx
ai_models/figures/

# 7. 敏感配置 (如数据库密码、云服务器秘钥)
.env
.env.local
.env.*.local
application-prod.yml

# 8. 过程文档
# ✅ Markdown/文本文件纳入版本控制（体积小、变更频繁、需保护）
# ❌ 二进制文档忽略（体积大、不易 diff）
docs/
!docs/
!docs/**/*.md
!docs/**/*.txt
docs/**/*.docx
docs/**/*.xlsx
docs/**/*.pdf
docs/**/*.doc
docs/**/*.ppt
docs/**/*.pptx
docs/**/*.png
docs/**/*.jpg
docs/**/*.gif
docs/**/*.svg
!docs/assets/
!docs/assets/local-env-check.svg

# 🆕 合并 workorder: Spring Boot devtools
.spring-boot-devtools.properties
restartServer.dat

