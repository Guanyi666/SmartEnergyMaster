# Claude Code 本地个人设置（launch.json 可共享，settings.local 不提交）
.claude/settings.local.json
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/.vite/                  # 🆕 合并 workorder: Vite 缓存目录

# 5. 算法与数据泵：Python (针对 ai_models/ 目录)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
ai_models/env/
ai_models/venv/
ai_models/.venv/
data/.venv/
.venv/
Pipfile.lock

# 6. 🚨 核心防御：数据与大模型权重 (针对 data/ 和 ai_models/ 目录)
# 绝对不要把庞大的数据集和训练好的模型传到 Git 上！
data/*.csv
data/*.json
data/*.xlsx
# 允许提交一个非常小的示例文件供大家测试联调
!data/sample_data.csv

ai_models/**/*.h5
ai_models/**/*.pkl
ai_models/**/*.pt
ai_models/**/*.pth
ai_models/**/*.onnx

# 7. 敏感配置 (如数据库密码、云服务器秘钥)
.env
.env.local
.env.*.local
application-prod.yml

# 8. 过程文档（仅本地保留，不纳入版本控制）
docs/
!docs/
!docs/local-dev-setup-guide.md
!docs/assets/
!docs/assets/local-env-check.svg

# 🆕 合并 workorder: Spring Boot devtools
.spring-boot-devtools.properties
restartServer.dat

